---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

const docsHome = import.meta.env.BASE_URL;
---

<StarlightPage
  frontmatter={{
    title: "404",
    description: "Page not found.",
    template: "splash",
    editUrl: false,
  }}
  hasSidebar={false}
>
  <p>Page not found. Check the URL or try using the search bar.</p>
  <p><a href={docsHome}>Return to the RavenPorter docs home page.</a></p>
</StarlightPage>
